# Godot editor/cache artifacts
# Keep .godot/ tracked so CI can use pre-imported resources.
# Only exclude generated desktop/editor-only files:
.godot/editor/
.godot/mono/
.godot/uid_cache.bin

# Legacy Godot 3 import folder
.import/

# Godot export/build artifacts
/android/
/build/
/dist/
/export/
/exports/
*.pck
*.zip
*.apk
*.aab
*.exe
*.dmg
*.app
*.x86_64
*.arm64

# Logs and temporary files
*.log
*.tmp
*.temp
*.bak
*.swp
*~

# Local one-off Godot scratch scripts; canonical suites live under the tests directory.
/test.gd
/test.gd.uid
/test[0-9]*.gd
/test[0-9]*.gd.uid

# Local export presets may contain machine-specific paths/signing config.
/export_presets.cfg

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python cache
__pycache__/
*.pyc
